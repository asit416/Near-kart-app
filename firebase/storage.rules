// firebase/storage.rules
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Product images - sellers can upload, everyone can read
    match /products/{sellerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == sellerId
        && request.resource.size < 5 * 1024 * 1024  // Max 5MB
        && request.resource.contentType.matches('image/.*');
    }

    // User avatars
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024  // Max 2MB
        && request.resource.contentType.matches('image/.*');
    }

    // Shop images
    match /shops/{sellerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == sellerId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Admin uploads
    match /admin/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;  // Tighten with admin role check in production
    }
  }
}
