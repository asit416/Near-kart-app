// firebase/firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSeller() {
      return isAuth() &&
        exists(/databases/$(database)/documents/sellers/$(request.auth.uid));
    }

    // ─── Users Collection ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Sellers Collection ───────────────────────────────────────────────
    match /sellers/{sellerId} {
      allow read: if true; // Public - buyers can see seller info
      allow create: if isOwner(sellerId);
      allow update: if isOwner(sellerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Products Collection ──────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true; // Public - anyone can browse products
      allow create: if isSeller() && request.auth.uid == request.resource.data.sellerId;
      allow update: if isSeller() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── Orders Collection ────────────────────────────────────────────────
    match /orders/{orderId} {
      // Buyer can read their own orders; Seller can read orders for their shop
      allow read: if isAuth() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      // Only buyers can create orders
      allow create: if isAuth() && request.resource.data.buyerId == request.auth.uid;
      // Sellers can update status; buyers can cancel
      allow update: if isAuth() && (
        resource.data.sellerId == request.auth.uid ||
        resource.data.buyerId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── Reviews Collection ───────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAuth() && resource.data.buyerId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── Notifications Collection ─────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if false; // Only Cloud Functions create notifications
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ─── Transactions Collection ──────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuth() && (
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      allow write: if false; // Only Cloud Functions write transactions
    }

    // ─── Settings (Admin Only) ────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Analytics (Admin Only) ───────────────────────────────────────────
    match /analytics/{dateId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }

    // ─── Banners ──────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
